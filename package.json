{
  "name": "react-shahmat",
  "version": "2.1.0",
  "description": "A React chess board component with built-in game logic, animations, and sound effects. Features drag-and-drop, premoves, arrows, and visual indicators.",
  "main": "dist/index.js",
  "module": "dist/index.esm.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.esm.js",
      "require": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "rollup -c",
    "dev": "rollup -c --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepublishOnly": "npm run build"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  },
  "dependencies": {
    "dnd-core": "^16.0.1",
    "react-dnd": "^16.0.1",
    "react-dnd-touch-backend": "^16.0.1"
  },
  "devDependencies": {
    "@rollup/plugin-commonjs": "^28.0.3",
    "@rollup/plugin-node-resolve": "^16.0.1",
    "@rollup/plugin-terser": "^0.4.4",
    "@rollup/plugin-typescript": "^12.1.2",
    "@rollup/plugin-url": "^8.0.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^19.1.5",
    "@types/react-dom": "^19.1.5",
    "@typescript-eslint/eslint-plugin": "^8.33.0",
    "@typescript-eslint/parser": "^8.33.0",
    "audiosprite": "^0.7.2",
    "eslint": "^9.27.0",
    "eslint-plugin-react": "^7.32.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "jsdom": "^29.1.1",
    "postcss": "^8.5.4",
    "prettier": "^3.9.5",
    "rollup": "^4.62.2",
    "rollup-plugin-copy": "^3.5.0",
    "rollup-plugin-dts": "^6.2.1",
    "rollup-plugin-peer-deps-external": "^2.2.4",
    "rollup-plugin-postcss": "^4.0.2",
    "tslib": "^2.8.1",
    "typescript": "^5.9.3",
    "vitest": "^4.1.10"
  },
  "keywords": [
    "react",
    "chess",
    "chessboard",
    "game",
    "component",
    "typescript",
    "shahmat",
    "interactive"
  ],
  "author": "Tibor Djurica Potpara <tibor.djurica@ojdip.net>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tibordp/react-shahmat.git"
  },
  "bugs": {
    "url": "https://github.com/tibordp/react-shahmat/issues"
  },
  "homepage": "https://github.com/tibordp/react-shahmat#readme"
}
